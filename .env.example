# Exact public browser origin. Production must use HTTPS.
APP_ORIGIN=https://chat.example.com

# Main publishes latest plus immutable sha-* tags. Pin sha-* in production.
VEILINK_IMAGE=ghcr.io/ovinc-cn/veilink:latest

# Publish only on loopback behind an external TLS reverse proxy.
APP_BIND_IP=127.0.0.1
APP_PORT=3000

# Optional native HTTPS. Set both to readable PEM paths inside the container.
# With Compose, mount both files read-only through an override before setting
# these container paths.
TLS_CERT_FILE=
TLS_KEY_FILE=

# Trust only the direct reverse-proxy hop.
VEILINK_SUBNET=172.30.0.0/24
VEILINK_GATEWAY=172.30.0.1
TRUST_PROXY_CIDRS=172.30.0.1/32

# External Redis stores short-lived signaling metadata. Both redis:// and rediss:// are supported.
REDIS_URL=redis://veilink:replace-with-a-strong-password@redis.example.com:6379/0
REDIS_KEY_PREFIX=veilink:production

# Generate independently with: openssl rand -hex 32
STATE_HMAC_SECRET=replace-with-64-random-hex-characters-before-deploying

# Cloudflare Realtime TURN. The long-lived key stays on the Go server; browsers
# receive only short-lived relay credentials. Valid TTL: 300-172800 seconds;
# the default is 25 hours.
CLOUDFLARE_TURN_KEY_ID=replace-with-the-32-character-key-id
CLOUDFLARE_TURN_API_TOKEN=replace-with-the-turn-key-api-token
TURN_CREDENTIAL_TTL_SECONDS=90000

# Optional shared password required only when creating a new room. Leave empty
# to allow anyone to create rooms. It is unrelated to invitation PINs and keys.
ROOM_CREATION_PASSWORD=

# Browsers can resume the same room membership within this lease window (5-900).
RECONNECT_GRACE_SECONDS=30

# Maximum time to establish all initial relay-only peer connections (30-300).
# A slow connection warning and ICE restart start after the first 30 seconds.
PEER_CONNECTION_TIMEOUT_SECONDS=90

# Initial room lifetime and the full lifetime restored by each host renewal
# (60-86400 seconds).
ROOM_TTL_SECONDS=86400

# Redis-backed capacity and abuse controls. Tune per-IP limits carefully for
# shared NATs.
# Global active room limit (1-100000).
MAX_ROOMS=1000
# Global connection limit (1-100000).
MAX_CONNECTIONS=2048
# Per-IP connection limit (1-10000).
MAX_CONNECTIONS_PER_IP=64
# Per-IP active room limit (1-10000).
MAX_ROOMS_PER_IP=32
# Per-IP room creation attempts per minute (1-10000).
ROOM_CREATE_ATTEMPTS_PER_MINUTE=20

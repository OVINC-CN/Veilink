# Public HTTPS origin. It must exactly match the origin shown by the browser.
APP_ORIGIN=https://chat.example.com

# Main publishes `latest` plus immutable `sha-*` tags to GHCR. Pin `sha-*` in
# production; Compose can also build these names locally.
VEILINK_IMAGE=ghcr.io/ovinc-cn/veilink:latest
VEILINK_TURN_IMAGE=ghcr.io/ovinc-cn/veilink-turn:latest

# The application is published on loopback for an external TLS reverse proxy.
APP_BIND_IP=127.0.0.1
APP_PORT=3000

# Optional native HTTPS. Set both to readable PEM paths inside the app
# container and mount only those files read-only; otherwise terminate HTTPS at
# the external reverse proxy.
TLS_CERT_FILE=
TLS_KEY_FILE=

# Only the direct reverse-proxy hop may be trusted. These defaults match the
# fixed Compose bridge below when the proxy runs on the Docker host.
VEILINK_SUBNET=172.30.0.0/24
VEILINK_GATEWAY=172.30.0.1
TRUST_PROXY_CIDRS=172.30.0.1/32

# Rooms are memory-only. Values above 86400 are rejected by the application.
ROOM_TTL_SECONDS=86400

# Browser-visible TURN endpoints. Direct and STUN-only connections are disabled.
TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
TURN_REALM=turn.example.com
TURN_CREDENTIAL_TTL_SECONDS=600

# In-memory abuse controls. Tune carefully for shared NATs.
MAX_CONNECTIONS=2048
MAX_CONNECTIONS_PER_IP=64
MAX_ROOMS_PER_IP=32
ROOM_CREATE_ATTEMPTS_PER_MINUTE=20

# Generate with: openssl rand -hex 32
# Keep the same value in the app and coturn containers; never commit the real value.
TURN_REST_SECRET=replace-with-64-random-hex-characters-before-deploying

# Public IPv4 address that forwards the TURN and relay ports to this host.
TURN_BIND_IP=0.0.0.0
TURN_EXTERNAL_IP=203.0.113.10
# Usually left empty; the coturn entrypoint detects its container IPv4 address.
TURN_PRIVATE_IP=
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Optional TURN-over-TLS is enabled through docker-compose.turns.yml.example.
TURN_TLS_CERT_PATH=/absolute/path/to/fullchain.pem
TURN_TLS_KEY_PATH=/absolute/path/to/privkey.pem

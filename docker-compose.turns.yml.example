# Optional TURN-over-TLS overlay. TURN TLS terminates in coturn; it is not HTTP
# and normally cannot be terminated by the application's HTTPS reverse proxy.
services:
  turn:
    environment:
      TURN_TLS_ENABLED: "true"
      TURN_TLS_CERT_FILE: /run/secrets/turn-cert.pem
      TURN_TLS_KEY_FILE: /run/secrets/turn-key.pem
    ports:
      - "${TURN_BIND_IP:-0.0.0.0}:5349:5349/tcp"
    volumes:
      - "${TURN_TLS_CERT_PATH:?Set an absolute certificate path}:/run/secrets/turn-cert.pem:ro"
      - "${TURN_TLS_KEY_PATH:?Set an absolute private-key path}:/run/secrets/turn-key.pem:ro"
